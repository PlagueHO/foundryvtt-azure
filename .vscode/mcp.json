{
  "inputs": [],
  "servers": {
    "azure-verified-module-bicep": {
      "type": "sse",
      "url": "https://gitmcp.io/Azure/bicep-registry-modules"
    },
    "github": {
      "url": "https://api.githubcopilot.com/mcp/",
      "type": "http"
    },
    "github-agentic-workflows": {
      "command": "gh",
      "args": [
        "aw",
        "mcp-server"
      ],
      "cwd": "${workspaceFolder}"
    },
    "microsoft-learn": {
      "url": "https://learn.microsoft.com/api/mcp",
      "type": "http"
    }
  }
}
